# ──────────────────────────────────────────────────────────────────────────
# PortOne V2
# ──────────────────────────────────────────────────────────────────────────

# PortOne V2 API Secret. PortOne 콘솔 → 결제 연동 → V2 API → API Secret 발급.
# 발급 직후 표시되는 긴 random 문자열을 즉시 복사. 이름(예: "DASHBOARD") 아님.
PORTONE_API_KEY=

# PortOne V2 Store ID. 같은 화면에서 "Store ID" 옆 store-xxxxxxxx 형식 복사.
# V2 list_payments 는 storeId 필수.
PORTONE_STORE_ID=

# ──────────────────────────────────────────────────────────────────────────
# 토스페이먼츠 (2026-06-19 결제 PG 전환분)
# ──────────────────────────────────────────────────────────────────────────

# 토스페이먼츠 Secret Key. 개발자센터 → API 키 → "API 개별 연동 키"의 시크릿 키.
# 거래 조회(GET /v1/transactions)만 사용. 실매출은 라이브(live_sk_...), 테스트는 test_sk_... 키.
# 미설정 시 토스 매출은 집계에서 제외된다. PortOne 키와 둘 다 있으면 합산.
TOSS_SECRET_KEY=

# ──────────────────────────────────────────────────────────────────────────
# Meta Marketing API (Facebook/Instagram 광고)
# ──────────────────────────────────────────────────────────────────────────

# 광고 인사이트 조회용 access token. 페이스북 비즈니스 → 비즈니스 설정 →
# 사용자 → 시스템 사용자 → "관리자 시스템 사용자" 생성 후 "토큰 생성" 으로
# ads_read 권한 포함해 발급. long-lived 토큰 권장 (만료 없음).
# 절대 NEXT_PUBLIC_ 접두사 사용 금지 — 서버 사이드에서만 사용.
META_ACCESS_TOKEN=

# 광고계정 ID. 광고관리자 좌측 상단 "광고 계정 ID: act_숫자" 형식 그대로 복사.
# 또는 숫자만 입력해도 코드에서 자동으로 act_ 접두사 추가.
META_AD_ACCOUNT_ID=

# (선택) Graph API 버전. 미설정 시 v21.0 사용. Meta 가 새 버전 릴리즈하면
# 여기만 바꿔서 마이그레이션.
META_API_VERSION=

# (선택) 광고계정 통화 override. 미설정 시 Meta API 로 자동 감지(GET act_xxx?fields=currency).
# 계정이 USD(예: Read My Saju_USD)면 광고비/예산을 일자별 환율로 KRW 환산한다(lib/fx.ts).
# 자동 감지가 실패하면 USD 로 가정하므로, KRW 계정을 쓰면 여기 KRW 를 명시.
META_ACCOUNT_CURRENCY=

# ── (선택) 광고계정 전환: 특정 날짜 이전은 이전 계정, 이후는 신규 계정에서 광고비 수집 ──
# 예) 2026-07-01 부터 USD 계정으로 갈아탐 → 그 전 광고비는 이전(원화) 계정에서 가져와야 함.
#   META_AD_ACCOUNT_ID          = 신규(전환일 이후) 계정   ← 위에서 이미 설정
#   META_AD_ACCOUNT_ID_PREV     = 이전(전환일 이전) 계정 act_숫자
#   META_ACCOUNT_CUTOVER        = 전환 기준일 YYYY-MM-DD (이 날부터 신규 계정)
# 셋 다 있으면 날짜 기준으로 두 계정을 갈라 수집·합산. 미설정이면 신규 계정 단일.
# 통화는 계정별 자동 감지(이전=원화면 환산 skip). override 필요시 아래 사용.
META_AD_ACCOUNT_ID_PREV=
META_ACCOUNT_CUTOVER=
# 이전 계정이 다른 토큰이어야 접근되면(같은 시스템 사용자에 할당했으면 불필요):
META_ACCESS_TOKEN_PREV=
# 이전 계정 통화 override (자동 감지 실패 대비, 보통 KRW):
META_ACCOUNT_CURRENCY_PREV=

# ──────────────────────────────────────────────────────────────────────────
# 비즈니스 계수 (광고 손익 계산용 default)
# ──────────────────────────────────────────────────────────────────────────

# PG 수수료율 (소수). default 0.0352 (= 3.52%). 사장님 계약 PG 사 변경 시 조정.
DEFAULT_PG_FEE_RATE=0.0352

# 보고서 1건당 OpenAI/Anthropic API 비용 (KRW). default 250원/건.
DEFAULT_REPORT_COST_PER_UNIT=250

# 일별 집계 기준 타임존 (IANA). default Asia/Seoul.
DASHBOARD_TIMEZONE=Asia/Seoul

# ──────────────────────────────────────────────────────────────────────────
# 인증
# ──────────────────────────────────────────────────────────────────────────

# 대시보드 로그인 비밀번호. 비워두면 누구나 접근 가능 → 반드시 설정.
DASHBOARD_PASSWORD=

# 세션 쿠키 서명용 시크릿. openssl rand -hex 32 또는
# https://generate-secret.vercel.app/32 에서 발급.
SESSION_SECRET=
