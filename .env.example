# PortOne V2 API Secret. PortOne 콘솔 → 결제 연동 → V2 API → API Secret 발급
# 발급 직후 표시되는 긴 random 문자열을 즉시 복사. 이름(예: "DASHBOARD") 아님.
PORTONE_API_KEY=

# PortOne V2 Store ID. 같은 화면에서 "Store ID" 옆 store-xxxxxxxx 형식 복사.
# V2 list_payments 는 storeId 필수.
PORTONE_STORE_ID=

# 대시보드 로그인 비밀번호. 비워두면 누구나 접근 가능 → 반드시 설정.
DASHBOARD_PASSWORD=

# 세션 쿠키 서명용 시크릿. openssl rand -hex 32 또는
# https://generate-secret.vercel.app/32 에서 발급.
SESSION_SECRET=
